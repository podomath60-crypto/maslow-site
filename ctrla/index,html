<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CtrlA Copy View</title>
  <style>
    :root{
      --bg:#f5f7fb;
      --paper:#ffffff;
      --ink:#16181d;
      --line:#e7ecf2;
      --shadow:0 18px 38px rgba(15,23,42,.08);
      --page:920px;
    }
    *{box-sizing:border-box}
    html,body{margin:0;padding:0;background:var(--bg);color:var(--ink);font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,"Noto Sans KR","Apple SD Gothic Neo",sans-serif}
    body{min-width:0}
    .page{min-height:100vh;padding:18px 0 72px}
    .top-mini{max-width:var(--page);margin:0 auto 10px;padding:0 14px;display:flex;align-items:center;justify-content:space-between;gap:10px}
    .brand-toggle{border:none;background:transparent;color:#111318;font-size:17px;font-weight:950;letter-spacing:-0.04em;padding:4px 2px;user-select:none}
    .helper{font-size:12px;color:#7d8794;font-weight:800;user-select:none}
    .shell{max-width:var(--page);margin:0 auto;padding:0 14px}
    .paper{background:var(--paper);border:1px solid var(--line);box-shadow:var(--shadow);border-radius:28px;overflow:hidden}
    .article{padding:26px 22px 34px}
    .loading{min-height:140px;display:flex;align-items:center;justify-content:center;color:#7d8794;font-size:15px;font-weight:800}
    .lead{margin:0 0 30px;font-size:20px;line-height:1.85;color:#2f3742;font-weight:700;word-break:keep-all;white-space:pre-line}
    .lead.is-empty{display:none}
    .block{margin:0 0 72px}
    .block:last-child{margin-bottom:0}
    .section-kicker{margin:0 0 8px;font-size:12px;font-weight:900;color:#7d8794;letter-spacing:.08em;text-transform:uppercase}
    .section-title{margin:0 0 16px;font-size:34px;line-height:1.3;font-weight:950;letter-spacing:-0.04em;word-break:keep-all}
    .section-image-stack{display:grid;gap:18px;margin:24px 0 28px}
    .figure{margin:22px 0 26px}
    .figure img{width:100%;max-width:680px;display:block;margin:0 auto;border-radius:22px;border:1px solid #ebeff5;background:#f0f4f8}
    .paragraphs{display:grid;gap:22px}
    .paragraph{margin:0;font-size:19px;line-height:2.02;color:#2e3741;font-weight:500;word-break:keep-all;white-space:pre-line}
    .basic-info-slider{margin:34px 0 14px;padding:18px;border-radius:24px;background:#fbfcff;border:1px solid #e9eef5;display:none}
    .basic-info-slider.show{display:block}
    .basic-info-slider-head{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:12px}
    .basic-info-slider-title{margin:0;font-size:16px;font-weight:950;color:#1d2430;letter-spacing:-0.03em}
    .basic-info-slider-sub{font-size:12px;font-weight:800;color:#7d8794}
    .basic-info-slider-track{display:flex;gap:12px;overflow-x:auto;-webkit-overflow-scrolling:touch;padding-bottom:4px}
    .basic-info-slider-track::-webkit-scrollbar{display:none}
    .basic-info-card{flex:0 0 260px;width:260px;border-radius:20px;overflow:hidden;border:1px solid #e9eef5;background:#fff;box-shadow:0 10px 24px rgba(15,23,42,.05)}
    .basic-info-card img{display:block;width:100%;height:188px;object-fit:cover;background:#f1f5f9}
    .basic-info-card-body{padding:10px 12px}
    .basic-info-card-label{font-size:13px;font-weight:900;color:#334155}
    .info-strip{margin:30px 0;padding:18px 18px;border-radius:22px;background:#fbfcff;border:1px solid #e9eef5;display:none}
    .info-strip.show{display:block}
    .info-strip-title{font-size:15px;font-weight:900;margin:0 0 10px;color:#1d2430}
    .thumb-lines{display:grid;gap:8px}
    .thumb-line{font-size:16px;font-weight:800;color:#334155}
    .cta{margin-top:40px;padding:24px;border-radius:24px;background:#fbfcff;border:1px solid #e9eef5}
    .cta-title{margin:0 0 8px;font-size:22px;font-weight:900;letter-spacing:-0.04em}
    .cta-text{margin:0;font-size:16px;line-height:1.75;color:#475161;font-weight:700;white-space:pre-line}
    .hashtags{margin-top:26px;display:flex;flex-wrap:wrap;gap:10px}
    .tag{display:inline-flex;align-items:center;min-height:34px;padding:0 12px;border-radius:999px;background:#eef5ff;border:1px solid #d5e6ff;color:#2369d9;font-size:13px;font-weight:900}
    @media (max-width: 900px){
      .page{padding:12px 0 40px}
      .shell{padding:0 10px}
      .top-mini{padding:0 10px}
      .article{padding:20px 16px 28px}
      .lead{font-size:18px;line-height:1.9}
      .section-title{font-size:30px}
      .paragraph{font-size:17px;line-height:1.92}
      .helper{display:none}
    }
  </style>
</head>
<body>
  <div class="page">
    <div class="top-mini">
      <button type="button" class="brand-toggle" id="brandToggleBtn">Maslow</button>
      <div class="helper">Ctrl+A → Ctrl+C → 네이버 붙여넣기</div>
    </div>

    <div class="shell">
      <article class="paper">
        <div class="article">
          <div class="loading" id="loadingText">복사용 본문을 불러오는 중입니다.</div>

          <p class="lead is-empty" id="leadDisplay"></p>
          <div id="articleSections"></div>

          <div class="basic-info-slider" id="basicInfoSlider">
            <div class="basic-info-slider-head">
              <h3 class="basic-info-slider-title">기본정보 이미지</h3>
              <div class="basic-info-slider-sub">하단 고정 카드</div>
            </div>
            <div class="basic-info-slider-track" id="basicInfoTrack"></div>
          </div>

          <div class="info-strip" id="thumbStrip">
            <div class="info-strip-title">썸네일 문구</div>
            <div class="thumb-lines" id="thumbLines"></div>
          </div>

          <section class="cta">
            <h3 class="cta-title" id="ctaLabelDisplay">문의하기</h3>
            <p class="cta-text" id="ctaTextDisplay">문의 문구를 입력하세요.</p>
          </section>

          <div class="hashtags" id="tagWrap"></div>
        </div>
      </article>
    </div>
  </div>

  <script>
    const CONFIG = {
      adminListUrl: 'https://script.google.com/macros/s/AKfycbznhBvYFIv_GKeNoGIPFTi_mIXXH04BOvYrb4ZN9dk_Cc4Xjir3TP_vL3bbPrLLxgg2/exec'
    };

    const state = {
      blogId: '',
      row: null,
      tags: [],
      thumbs: [],
      cta: { label:'', text:'' },
      sectionBlocks: [],
      imageLayout: null
    };

    const els = {
      loadingText: document.getElementById('loadingText'),
      leadDisplay: document.getElementById('leadDisplay'),
      articleSections: document.getElementById('articleSections'),
      basicInfoSlider: document.getElementById('basicInfoSlider'),
      basicInfoTrack: document.getElementById('basicInfoTrack'),
      thumbStrip: document.getElementById('thumbStrip'),
      thumbLines: document.getElementById('thumbLines'),
      ctaLabelDisplay: document.getElementById('ctaLabelDisplay'),
      ctaTextDisplay: document.getElementById('ctaTextDisplay'),
      tagWrap: document.getElementById('tagWrap'),
      brandToggleBtn: document.getElementById('brandToggleBtn')
    };

    function text(v){ return String(v == null ? '' : v).trim(); }
    function esc(v){
      return String(v == null ? '' : v).replace(/[&<>"']/g, function(s){
        return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;', "'":'&#39;'})[s];
      });
    }
    function parseJson(v, fallback){
      if(v == null || v === '') return fallback;
      if(typeof v === 'object') return v;
      try{
        const x = JSON.parse(v);
        return x == null ? fallback : x;
      }catch(e){
        return fallback;
      }
    }
    function getParam(name){ return new URLSearchParams(location.search).get(name) || ''; }
    function fetchPostJson(payload){
      return fetch(CONFIG.adminListUrl, {
        method:'POST',
        mode:'cors',
        headers:{'Content-Type':'text/plain;charset=UTF-8'},
        body: JSON.stringify(payload)
      }).then(function(res){
        if(!res.ok) throw new Error('요청 실패: ' + res.status);
        return res.json();
      });
    }
    function formatDisplayText(v){
      return text(v).replace(/\s*\/\s*/g, '\n').replace(/\n{3,}/g, '\n\n').trim();
    }
    function buildSectionBlocksFromRow(row){
      const stored = parseJson(row && row.sectionStructureJson || '[]', []);
      if(Array.isArray(stored) && stored.length){
        return stored.map(function(sec, idx){
          return {
            sectionKey: 'section_' + (idx + 1),
            heading: text(sec && sec.heading) || ('Section ' + (idx + 1)),
            paragraphs: Array.isArray(sec && sec.paragraphs) ? sec.paragraphs.map(function(v){ return text(v); }) : []
          };
        });
      }
      return [];
    }
    function getDynamicSectionOrder(){
      return (state.sectionBlocks || []).map(function(sec, idx){
        return text(sec && sec.sectionKey) || ('section_' + (idx + 1));
      }).filter(Boolean);
    }
    function getSectionLabelByKey(sectionKey){
      const order = getDynamicSectionOrder();
      const idx = order.indexOf(text(sectionKey));
      return idx >= 0 ? ('Section ' + (idx + 1)) : text(sectionKey);
    }
    function getSectionKeyFromLegacyParagraph(paragraph){
      const order = getDynamicSectionOrder();
      const count = order.length;
      if(!count) return '';
      const p = text(paragraph).toLowerCase();
      let n = 1;
      if(p === 'p1') n = 1;
      else if(p === 'p2' || p === 'p3') n = 2;
      else if(p === 'p4' || p === 'p5') n = 3;
      else if(p === 'p6') n = 4;
      else if(p === 'p7' || p === 'p8' || p === 'p9') n = 5;
      n = Math.max(1, Math.min(n, count));
      return 'section_' + n;
    }
    function normalizeImageLayout(layout){
      const sectionOrder = getDynamicSectionOrder();
      const out = { hero:'', sections:{} };
      sectionOrder.forEach(function(key){ out.sections[key] = []; });
      const src = parseJson(layout || '{}', {});
      if(src && typeof src === 'object'){
        out.hero = text(src.hero || '');
        const sections = src.sections || {};
        sectionOrder.forEach(function(key){
          out.sections[key] = Array.isArray(sections[key]) ? sections[key].map(text).filter(Boolean) : [];
        });
      }
      return out;
    }
    function hasMeaningfulImageLayout(layoutLike){
      const layout = normalizeImageLayout(layoutLike);
      if (text(layout.hero)) return true;
      return getDynamicSectionOrder().some(function(key){
        return Array.isArray(layout.sections[key]) && layout.sections[key].length > 0;
      });
    }
    function buildSavedAssetCollections_(row){
      const saved = parseJson(row && row.savedAssetFilesJson || '[]', []);
      const infos = parseJson(row && row.infoImageFilesJson || '[]', []);
      const snaps = parseJson(row && row.assetSnapshotJson || '[]', []);
      const snapById = {};
      snaps.forEach(function(s){ snapById[text(s.assetId)] = s || {}; });

      const infoIdMap = {};
      infos.forEach(function(info){
        const id = text(info && info.assetId);
        if(id) infoIdMap[id] = true;
      });

      const photoAssets = [];
      const basicInfoAssets = [];

      (saved || []).forEach(function(file){
        const id = text(file && file.assetId);
        if(!id) return;
        const snap = snapById[id] || {};
        const assetType = text(file && file.assetType) || text(snap && snap.assetType);
        const assetSource = text(file && file.assetSource) || text(snap && snap.assetSource);
        const kind = text(file && file.kind) || text(snap && snap.kind);
        const targetGroup = text(file && file.targetGroup) || text(snap && snap.targetGroup);
        const isBasicInfo =
          infoIdMap[id] ||
          targetGroup === 'basic_info' ||
          assetType === 'basic_info' ||
          assetSource === 'generated_from_lookup' ||
          kind === 'generated_from_lookup';

        const asset = {
          assetId: id,
          url: text(file && (file.url || file.previewUrl || file.originalUrl)),
          isHero: !!(file && file.isHero) || !!snap.isHero,
          paragraph: text(file && file.paragraph) || text(snap && snap.paragraph),
          sectionKey: text(file && (file.sectionKey || file.section_key)),
          assetType: assetType,
          assetSource: assetSource,
          kind: kind
        };
        if(!asset.url) return;
        if(isBasicInfo) basicInfoAssets.push(asset);
        else photoAssets.push(asset);
      });

      return { photos: photoAssets, basics: basicInfoAssets };
    }
    function buildInitialImageLayoutFromRow(row){
      const saved = buildSavedAssetCollections_(row);
      const photos = saved.photos || [];
      const layout = normalizeImageLayout({});
      const sectionKeys = getDynamicSectionOrder();
      const fallbackOrder = sectionKeys.slice();

      photos.forEach(function(photo){
        const id = text(photo && photo.assetId);
        if(!id) return;
        if(photo.isHero && !layout.hero){
          layout.hero = id;
          return;
        }
        const sectionKeyDirect = text(photo && photo.sectionKey);
        const paragraph = text(photo && photo.paragraph);
        let sectionKey = /^section_\d+$/i.test(sectionKeyDirect)
          ? sectionKeyDirect.toLowerCase()
          : getSectionKeyFromLegacyParagraph(paragraph);

        if(!sectionKey && fallbackOrder.length) sectionKey = fallbackOrder[0];
        if(!sectionKey) return;
        layout.sections[sectionKey] = layout.sections[sectionKey] || [];
        layout.sections[sectionKey].push(id);
      });

      return layout;
    }
    function buildAssetMapFromRow(row){
      const collections = buildSavedAssetCollections_(row);
      const map = {};
      (collections.photos || []).concat(collections.basics || []).forEach(function(asset){
        const id = text(asset && asset.assetId);
        if(id) map[id] = asset;
      });
      return map;
    }
    function getBasicInfoAssets(row){
      const collections = buildSavedAssetCollections_(row);
      return uniqueAssets(collections.basics || []);
    }
    function getSectionImagesMap(row){
      const assetMap = buildAssetMapFromRow(row || {});
      const bySection = {};

      if(state.imageLayout){
        Object.keys((state.imageLayout.sections || {})).forEach(function(key){
          bySection[key] = (state.imageLayout.sections[key] || []).map(function(assetId){
            return assetMap[text(assetId)] || null;
          }).filter(function(asset){
            return asset && asset.assetType !== 'basic_info' && asset.assetSource !== 'generated_from_lookup';
          });
        });
        return { bySection: bySection };
      }

      const photos = buildSavedAssetCollections_(row).photos || [];
      const sectionKeys = getDynamicSectionOrder();
      const fallbackOrder = sectionKeys.slice();

      photos.forEach(function(photo){
        const id = text(photo && photo.assetId);
        if(!id || !photo.url || photo.isHero) return;
        const sectionKeyDirect = text(photo && photo.sectionKey);
        const paragraph = text(photo && photo.paragraph);
        let sectionKey = /^section_\d+$/i.test(sectionKeyDirect)
          ? sectionKeyDirect.toLowerCase()
          : getSectionKeyFromLegacyParagraph(paragraph);

        if(!sectionKey && fallbackOrder.length) sectionKey = fallbackOrder[0];
        if(sectionKey){
          if(!bySection[sectionKey]) bySection[sectionKey] = [];
          bySection[sectionKey].push(photo);
        }
      });

      return { bySection: bySection };
    }
    function uniqueAssets(list){
      const seen = {};
      return (list || []).filter(function(v){
        const id = text(v && v.assetId) || text(v && v.url);
        if(!id || seen[id]) return false;
        seen[id] = true;
        return true;
      });
    }
    function renderFigure(asset, sectionKey, idx){
      if(!asset || !asset.url) return '';
      return '<div class="figure" data-section-key="' + esc(text(sectionKey)) + '" data-idx="' + idx + '"><img src="' + esc(asset.url) + '" alt="이미지" /></div>';
    }
    function renderParagraphList(list){
      return (list || []).map(function(p){
        const displayText = formatDisplayText(p);
        if(!text(displayText)) return '';
        return '<p class="paragraph">' + esc(displayText) + '</p>';
      }).filter(Boolean).join('');
    }
    function renderBasicInfoSlider(row){
      const basics = getBasicInfoAssets(row || {});
      if(!basics.length){
        els.basicInfoSlider.classList.remove('show');
        els.basicInfoTrack.innerHTML = '';
        return;
      }
      els.basicInfoSlider.classList.add('show');
      els.basicInfoTrack.innerHTML = basics.map(function(asset, idx){
        return '<div class="basic-info-card"><img src="' + esc(asset.url) + '" alt="기본정보 이미지 ' + (idx + 1) + '" /><div class="basic-info-card-body"><div class="basic-info-card-label">기본정보 ' + (idx + 1) + '</div></div></div>';
      }).join('');
    }
    function renderThumbs(){
      if(!state.thumbs.length){
        els.thumbStrip.classList.remove('show');
        els.thumbLines.innerHTML = '';
        return;
      }
      els.thumbStrip.classList.add('show');
      els.thumbLines.innerHTML = state.thumbs.map(function(v){
        return '<div class="thumb-line">' + esc(v) + '</div>';
      }).join('');
    }
    function renderTags(){
      if(!state.tags.length){
        els.tagWrap.innerHTML = '';
        return;
      }
      els.tagWrap.innerHTML = state.tags.map(function(v){
        return '<span class="tag">' + esc(v) + '</span>';
      }).join('');
    }
    function renderSections(row){
      const imgMap = getSectionImagesMap(row);
      const renderedSections = (state.sectionBlocks || []).map(function(sec){
        const secKey = text(sec.sectionKey);
        const paras = Array.isArray(sec.paragraphs) ? sec.paragraphs : [];
        const images = uniqueAssets(imgMap.bySection[secKey] || []);
        const imageHtml = images.map(function(asset, idx){ return renderFigure(asset, secKey, idx); }).join('');
        const paragraphHtml = renderParagraphList(paras);
        return '<section class="block">'
          + '<div class="section-kicker">' + esc(getSectionLabelByKey(secKey)) + '</div>'
          + '<h2 class="section-title">' + esc(text(sec.heading) || '섹션') + '</h2>'
          + (imageHtml ? '<div class="section-image-stack">' + imageHtml + '</div>' : '')
          + (paragraphHtml ? '<div class="paragraphs">' + paragraphHtml + '</div>' : '')
          + '</section>';
      }).join('');
      els.articleSections.innerHTML = renderedSections;
    }
    function renderAll(row){
      state.row = row;
      state.tags = parseJson(row.hashtagsJson || '[]', []).map(text).filter(Boolean);
      state.thumbs = parseJson(row.thumbnailTextJson || '[]', []).map(text).filter(Boolean);
      state.cta = parseJson(row.ctaJson || '{}', {});
      state.sectionBlocks = buildSectionBlocksFromRow(row);
      state.imageLayout = hasMeaningfulImageLayout(row.imageLayoutJson) ? normalizeImageLayout(row.imageLayoutJson) : buildInitialImageLayoutFromRow(row);

      const firstLead = (((state.sectionBlocks || [])[0] || {}).paragraphs || [])[0] || '';
      const lead = formatDisplayText(firstLead);
      els.leadDisplay.textContent = lead || '';
      els.leadDisplay.classList.toggle('is-empty', !text(lead));

      els.ctaLabelDisplay.textContent = text(state.cta.label) || '문의하기';
      els.ctaTextDisplay.textContent = text(row.ctaText || state.cta.text) || '문의 문구를 입력하세요.';

      renderSections(row);
      renderBasicInfoSlider(row);
      renderThumbs();
      renderTags();
      els.loadingText.style.display = 'none';
    }
    function buildMinimalRow(){
      return {
        blogId: state.blogId,
        sectionStructureJson: '[]',
        hashtagsJson: '[]',
        thumbnailTextJson: '[]',
        ctaJson: '{}',
        ctaText: '',
        infoImageFilesJson: '[]',
        assetSnapshotJson: '[]',
        heroImageUrl: ''
      };
    }
    function loadDraft(){
      state.blogId = text(getParam('blogId'));
      if(!state.blogId){
        renderAll(buildMinimalRow());
        return;
      }
      fetchPostJson({ action:'getBlogDraftDetail', blogId: state.blogId })
        .then(function(data){
          const row = data && (data.row || data.blog || data.item);
          if(!row) throw new Error('초안 데이터 없음');
          renderAll(row);
        })
        .catch(function(err){
          console.error(err);
          renderAll(buildMinimalRow());
          els.loadingText.textContent = '복사용 본문 로드 실패';
          els.loadingText.style.display = 'flex';
        });
    }

    els.brandToggleBtn.addEventListener('click', function(){
      history.back();
    });

    loadDraft();
  </script>
</body>
</html>
